#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <stdint.h>

int is_prime(int n) {
    if (n < 2) return 0;
    for (int i = 2; i * i <= n; i++)
        if (n % i == 0) return 0;
    return 1;
}

void xor8(const char *filename) {
    FILE *fp = fopen(filename, "rb");
    if (!fp) {
        perror("fopen");
        return;
    }
    uint8_t xor_sum = 0;
    int ch;
    while ((ch = fgetc(fp)) != EOF) {
        xor_sum ^= (uint8_t)ch;
    }
    fclose(fp);
    printf("XOR8 result: 0x%02X (%d)\n", xor_sum, xor_sum);
}

void xordod(const char *filename) {
    FILE *fp = fopen(filename, "rb");
    if (!fp) {
        perror("fopen");
        return;
    }
    uint8_t xor_sum = 0;
    int ch;
    while ((ch = fgetc(fp)) != EOF) {
        if (is_prime(ch)) {
            xor_sum ^= (uint8_t)ch;
        }
    }
    fclose(fp);
    printf("XORDOD result: 0x%02X (%d)\n", xor_sum, xor_sum);
}

void mask(const char *filename, unsigned int mask_val) {
    FILE *fp = fopen(filename, "rb");
    if (!fp) {
        perror("fopen");
        return;
    }
    int count = 0;
    int ch;
    while ((ch = fgetc(fp)) != EOF) {
        if ((ch & mask_val) == mask_val) {
            count++;
        }
    }
    fclose(fp);
    printf("MASK count: %d\n", count);
}

int main(int argc, char *argv[]) {
    if (argc < 3) {
        fprintf(stderr, "Usage: %s <file> <flag> [<hex>]\n", argv[0]);
        return 1;
    }

    if (strcmp(argv[2], "xor8") == 0) {
        xor8(argv[1]);
    } else if (strcmp(argv[2], "xordod") == 0) {
        xordod(argv[1]);
    } else if (strcmp(argv[2], "mask") == 0) {
        if (argc != 4) {
            fprintf(stderr, "mask requires a hex argument\n");
            return 1;
        }
        unsigned int hex_val;
        if (sscanf(argv[3], "%x", &hex_val) != 1) {
            fprintf(stderr, "Invalid hex value\n");
            return 1;
        }
        mask(argv[1], hex_val);
    } else {
        fprintf(stderr, "Unknown flag\n");
        return 1;
    }

    return 0;
}